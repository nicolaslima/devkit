{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devkit.dev/manifest.schema.json",
  "title": "devkit manifest",
  "type": "object",
  "required": ["app", "version", "entry", "files", "min_bun"],
  "properties": {
    "app": {
      "type": "string",
      "const": "devkit"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "entry": {
      "type": "string",
      "minLength": 1
    },
    "min_bun": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
